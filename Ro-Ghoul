local function getPlayerByPartialName(name)
    name = name:lower()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Name:lower():sub(1, #name) == name then
            return plr
        end
    end
    return nil
end

local function updateVisualListDisplay()
    local includeNames = {}
    local excludeNames = {}
    for k, _ in pairs(getgenv().IncludeList) do
        local formattedName = k:sub(1,1):upper() .. k:sub(2)
        table.insert(includeNames, formattedName)
    end
    for k, _ in pairs(getgenv().ExcludeList) do
        local formattedName = k:sub(1,1):upper() .. k:sub(2)
        table.insert(excludeNames, formattedName)
    end
    local incStr = "Include:\n " .. (#includeNames > 0 and table.concat(includeNames, ", ") or "(empty)")
    local excStr = "Exclude:\n " .. (#excludeNames > 0 and table.concat(excludeNames, ", ") or "(empty)")
    DisplayListLabel.Text = incStr .. "\n\n" .. excStr
end

local function toggleFilterMode()
    if getgenv().AimbotMode == "Exclude" then
        getgenv().AimbotMode = "Include"
    else
        getgenv().AimbotMode = "Exclude"
    end
    ModeLabel.Text = "Filter Mode: " .. getgenv().AimbotMode:upper()
    WLTextBox.PlaceholderText = "Switched to " .. getgenv().AimbotMode .. "!"
    getgenv().ActiveAimbotTarget = nil
    getgenv().ActiveTargetChar = nil
    updateVisualListDisplay()
end

updateVisualListDisplay()

-- Automatic server logout cleaner
Players.PlayerRemoving:Connect(function(player)
    local lowerName = player.Name:lower()
    if getgenv().IncludeList[lowerName] ~= nil or getgenv().ExcludeList[lowerName] ~= nil then
        getgenv().IncludeList[lowerName] = nil
        getgenv().ExcludeList[lowerName] = nil
        if getgenv().ActiveAimbotTarget == player then
            getgenv().ActiveAimbotTarget = nil
            getgenv().ActiveTargetChar = nil
        end
        updateVisualListDisplay()
    end
end)

WLTextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed and WLTextBox.Text ~= "" then
        local txt = WLTextBox.Text:match("^%s*(.-)%s*$")
        if txt:lower() == "!mode" then
            toggleFilterMode()
        elseif txt:lower() == "clear" or txt:lower() == "!clear" then
            getgenv().IncludeList = {}
            getgenv().ExcludeList = {}
            WLTextBox.PlaceholderText = "Lists completely cleared!"
            getgenv().ActiveAimbotTarget = nil
            getgenv().ActiveTargetChar = nil
            updateVisualListDisplay()
        else
            local targetPlayer = getPlayerByPartialName(txt)
            if targetPlayer then
                local lowerName = targetPlayer.Name:lower()
                if getgenv().AimbotMode == "Include" then
                    if getgenv().IncludeList[lowerName] then
                        getgenv().IncludeList[lowerName] = nil
                        WLTextBox.PlaceholderText = "Removed: " .. targetPlayer.Name
                    else
                        getgenv().IncludeList[lowerName] = true
                        WLTextBox.PlaceholderText = "Targeting: " .. targetPlayer.Name
                    end
                else
                    if getgenv().ExcludeList[lowerName] then
                        getgenv().ExcludeList[lowerName] = nil
                        WLTextBox.PlaceholderText = "Removed: " .. targetPlayer.Name
                    else
                        getgenv().ExcludeList[lowerName] = true
                        WLTextBox.PlaceholderText = "Whitelisted: " .. targetPlayer.Name
                    end
                end
                getgenv().ActiveAimbotTarget = nil
                getgenv().ActiveTargetChar = nil
            else
                WLTextBox.PlaceholderText = "User not found!"
            end
            updateVisualListDisplay()
        end
        WLTextBox.Text = ""
    end
end)

UIS.InputBegan:Connect(function(input, processed)
    if input.KeyCode == Enum.KeyCode.Minus then
        MainFrame.Visible = not MainFrame.Visible
        return
    end
    -- Asterisk keybind strictly swaps your strategy modes
    if input.KeyCode == Enum.KeyCode.Asterisk then
        toggleFilterMode()
        return
    end
    if processed then return end
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        getgenv().IsAimbotActive = true
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        getgenv().IsAimbotActive = false
        getgenv().ActiveAimbotTarget = nil
        getgenv().ActiveTargetChar = nil
    end
end)

local function isAllowedTarget(player)
    if not player then return false end
    local lowerName = player.Name:lower()
    if getgenv().AimbotMode == "Include" then
        return getgenv().IncludeList[lowerName] == true
    else
        return not (getgenv().ExcludeList[lowerName] == true)
    end
end

local function getAnyValidPart(model)
    return model:FindFirstChild("Head") or model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart or model:FindFirstChild("Torso") or model:FindFirstChildWhichIsA("BasePart")
end

local function isValidTarget(character)
    if not character or not character:IsDescendantOf(workspace) then return false end
    local plr = Players:GetPlayerFromCharacter(character)
    if not isAllowedTarget(plr) then return false end
    local hum = character:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
        local part = getAnyValidPart(character)
    if not part then return false end
    
    local _, onScreen = Camera:WorldToViewportPoint(part.Position)
    if not onScreen then return false end
    
    return true
end

local function getClosestToCrosshair()
    local closestDistance = 99999
    local closestPart = nil
    local chosenPlayer = nil
    local screenCenter = Camera.ViewportSize / 2
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and isAllowedTarget(plr) and plr.Character then
            local model = plr.Character
            local hum = model:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local part = getAnyValidPart(model)
                if part then
                    local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local dist = (screenCenter - Vector2.new(sp.X, sp.Y)).Magnitude
                        if dist < closestDistance then
                            closestDistance = dist
                            closestPart = part
                            chosenPlayer = plr
                        end
                    end
                end
            end
        end
    end
    return closestPart, chosenPlayer
end

getgenv().GetDevTarget = function(fallback)
    if getgenv().ActiveTargetChar and isValidTarget(getgenv().ActiveTargetChar) then
        local part = getAnyValidPart(getgenv().ActiveTargetChar)
        return part and part.Position or fallback
    end
    local target = getClosestToCrosshair()
    return target and target.Position or fallback
end

RunService.RenderStepped:Connect(function()
    if getgenv().IsAimbotActive then
        if getgenv().ActiveTargetChar and isValidTarget(getgenv().ActiveTargetChar) then
            local targetPart = getAnyValidPart(getgenv().ActiveTargetChar)
            if targetPart then
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetPart.Position)
            end
        else
            getgenv().ActiveAimbotTarget = nil
            getgenv().ActiveTargetChar = nil
            
            local nextPart, nextPlayer = getClosestToCrosshair()
            if nextPart and nextPlayer then
                getgenv().ActiveAimbotTarget = nextPlayer
                getgenv().ActiveTargetChar = nextPlayer.Character
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, nextPart.Position)
            end
        end
    end
end)
