local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local isAiming = false
local menuOpen = true
local espObjects = {}
local fovRadius = 150

local menuPos = Vector2.new(40, 100)
local isDragging = false
local dragOffset = Vector2.new(0, 0)
local menuSize = Vector2.new(250, 115) -- Reduced height since Boss/NPC rows are gone

-- Drawing Objects
local background = Drawing.new("Square")
local uiTitle = Drawing.new("Text")
local uiStatus1 = Drawing.new("Text")
local uiFov = Drawing.new("Text")
local uiHelp = Drawing.new("Text")
local fovCircle = Drawing.new("Circle")

local function initUI()
	background.Size = menuSize
	background.Position = menuPos
	background.Color = Color3.fromRGB(5, 5, 5)
	background.Transparency = 0.85
	background.Filled = true
	background.Thickness = 2
	background.Visible = true

	uiTitle.Size = 15
	uiTitle.Color = Color3.fromRGB(200, 255, 255)  -- soft white-blue
	uiTitle.Outline = false
	uiTitle.Visible = true

	for _, txt in {uiStatus1, uiFov} do
		txt.Size = 13
		txt.Color = Color3.fromRGB(255, 255, 255)  -- white text
		txt.Outline = false
		txt.Visible = true
	end

	uiHelp.Text = "[-] Toggle Menu | [ & ] FOV" -- Removed 'Cycle Target' help text
	uiHelp.Size = 11
	uiHelp.Color = Color3.fromRGB(180, 180, 180)
	uiHelp.Outline = false
	uiHelp.Visible = true
end
initUI()

fovCircle.Thickness = 1
fovCircle.Color = Color3.fromRGB(255, 255, 255)
fovCircle.Filled = false
fovCircle.Transparency = 0.55
fovCircle.NumSides = 48
fovCircle.Visible = true

local function updateMenu()
	if not menuOpen then return end

	if isDragging then
		local mousePos = UIS:GetMouseLocation()
		menuPos = mousePos + dragOffset
	end

	background.Position = menuPos
	background.Size = menuSize

	uiTitle.Position = menuPos + Vector2.new(10, 8)
	uiTitle.Text = "Ro-Ghoul Script"

	uiStatus1.Position = menuPos + Vector2.new(15, 34)
	uiFov.Position = menuPos + Vector2.new(15, 58)
	uiHelp.Position = menuPos + Vector2.new(15, 82)

	uiStatus1.Text = "Players: ON"
	uiStatus1.Color = Color3.fromRGB(0, 255, 100)   -- Green ON

	uiFov.Text = "FOV Radius: " .. fovRadius .. " px"
end

local function getAnyValidPart(model)
	return model.PrimaryPart or model:FindFirstChild("HumanoidRootPart") 
		or model:FindFirstChild("Torso") or model:FindFirstChildWhichIsA("BasePart")
end

local function getClosestToCrosshair()
	local closestDistance = fovRadius
	local closestPart = nil
	local screenCenter = Camera.ViewportSize / 2

	local targets = {}

	-- Target players selectively without scanning map data
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer and plr.Character then
			table.insert(targets, plr.Character)
		end
	end

	-- Process the specific targets compiled
	for _, model in ipairs(targets) do
		local hum = model:FindFirstChildOfClass("Humanoid")
		if hum and hum.Health > 0 and model ~= LocalPlayer.Character then
			local part = getAnyValidPart(model)
			if part then
				local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
				if onScreen then
					local dist = (screenCenter - Vector2.new(sp.X, sp.Y)).Magnitude
					if dist < closestDistance then
						closestDistance = dist
						closestPart = part
					end
				end
			end
		end
	end

	return closestPart
end

-- Input
UIS.InputBegan:Connect(function(input, processed)
	if input.KeyCode == Enum.KeyCode.Minus then
		menuOpen = not menuOpen
		local v = menuOpen
		background.Visible = v
		uiTitle.Visible = v
		uiStatus1.Visible = v
		uiFov.Visible = v
		uiHelp.Visible = v
		return
	end

	if not menuOpen then return end

	-- Completely removed the KeyCode.Z target cycling block

	if input.KeyCode == Enum.KeyCode.LeftBracket then
		fovRadius = math.max(10, fovRadius - 10)
		return
	end
	if input.KeyCode == Enum.KeyCode.RightBracket then
		fovRadius = math.min(800, fovRadius + 10)
		return
	end

	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		local mp = UIS:GetMouseLocation()
		if mp.X >= menuPos.X and mp.X <= menuPos.X + menuSize.X 
		   and mp.Y >= menuPos.Y and mp.Y <= menuPos.Y + menuSize.Y then
			isDragging = true
			dragOffset = menuPos - mp
			return
		end
	end

	if processed then return end
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		isAiming = true
	end
end)

UIS.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then isDragging = false end
	if input.UserInputType == Enum.UserInputType.MouseButton2 then isAiming = false end
end)

local function createESP(player)
	if espObjects[player] then return end
	espObjects[player] = { Box = Drawing.new("Square") }
end

local function removeESP(player)
	if espObjects[player] then
		for _, obj in pairs(espObjects[player]) do
			if obj and obj.Remove then obj:Remove() end
		end
		espObjects[player] = nil
	end
end

Players.PlayerRemoving:Connect(removeESP)

getgenv().GetDevTarget = function(fallback)
	local target = getClosestToCrosshair()
	return target and target.Position or fallback
end

-- Main Loop
RunService.RenderStepped:Connect(function()
	updateMenu()

	fovCircle.Position = Camera.ViewportSize / 2
	fovCircle.Radius = fovRadius

	if isAiming then
		local targetPart = getClosestToCrosshair()
		if targetPart then
			Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, targetPart.Position)
		end
	end

	-- ESP for players only
	local validThisFrame = {}
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer and plr.Team ~= LocalPlayer.Team then
			local char = plr.Character
			local hum = char and char:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				local root = getAnyValidPart(char)
				if root then
					validThisFrame[plr] = true
					createESP(plr)
					local esp = espObjects[plr]

					local top = Camera:WorldToViewportPoint(root.Position)
					-- Custom ESP box drawing logic continues here...
				end
			end
		end
	end
end)
