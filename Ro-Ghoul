local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local StarterGui = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

local Settings = {
    Enabled = true,
    HoldKey = Enum.UserInputType.MouseButton2,
    FOV = 140,
    TargetMode = "Boss",
    TargetPart = "Torso",
    Smoothing = 0.00,
    HitChance = 100,
    Prediction = 0.12,
    PlayerPrediction = 0.08,
    DrawFOV = true,
    FOVColor = Color3.fromRGB(255, 255, 255),
    FOVThickness = 2
}

local BossKeywords = {"Arima", "Kaneki", "Jason", "Yamori", "Eto", "Tatara", "Noro", "Ayato", "Hinami", "Juuzou", "Yoshimura", "Shachi", "Roma", "Donato", "Furuta", "Rize", "Suzuya", "Boss", "Raid", "Fighter", "Elite"}

local CurrentTarget = nil
local LastLockedName = ""
local NotificationCount = 0
local CurrentBossModel = nil
local FOVCircle = Drawing.new("Circle")

FOVCircle.Thickness = Settings.FOVThickness
FOVCircle.Color = Settings.FOVColor
FOVCircle.Transparency = 0.75
FOVCircle.Filled = false
FOVCircle.NumSides = 64

local function ShowToast(message)
    StarterGui:SetCore("SendNotification", {Title = "Ro Ghoul", Text = message, Duration = 2.5})
end

ShowToast("Script loaded.")

local function GetBossDisplayName(model)
    if not model then return "Unknown" end
    return model.Name
end

local function IsValidBoss(model)
    if not model or not model:FindFirstChild("Humanoid") or model.Humanoid.Health <= 0 then return false end
    local hum = model.Humanoid
    if hum.MaxHealth >= 5000 then return true end
    
    local name = model.Name:lower()
    for _, kw in ipairs(BossKeywords) do
        if name:find(kw:lower()) then return true end
    end
    return false
end

local function IsValidPlayer(target)
    if not target or not target:FindFirstChild("Humanoid") or target.Humanoid.Health <= 0 then return false end
    local plr = Players:GetPlayerFromCharacter(target)
    if not plr or plr == LocalPlayer then return false end
    if plr.Team and LocalPlayer.Team and plr.Team == LocalPlayer.Team then return false end
    return true
end

local function GetClosestTarget()
    local closest = nil
    local bestDist = Settings.FOV
    local mousePos = Camera.ViewportSize / 2

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local valid = false
            if Settings.TargetMode == "Boss" then
                valid = IsValidBoss(obj)
            else
                valid = IsValidPlayer(obj)
            end
            
            if valid then
                local part = obj:FindFirstChild(Settings.TargetPart) 
                          or obj:FindFirstChild("UpperTorso") 
                          or obj:FindFirstChild("HumanoidRootPart")
                
                if part then
                    local screen, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen then
                        local dist = (Vector2.new(screen.X, screen.Y) - mousePos).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            closest = {Part = part, Model = obj}
                        end
                    end
                end
            end
        end
    end
    return closest
end

local function PredictPosition(part)
    local pred = Settings.TargetMode == "Boss" and Settings.Prediction or Settings.PlayerPrediction
    return part.Position + (part.Velocity * pred)
end

RunService.RenderStepped:Connect(function()
    if Settings.DrawFOV then
        FOVCircle.Position = Camera.ViewportSize / 2
        FOVCircle.Radius = Settings.FOV
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end

    if not Settings.Enabled or not UserInputService:IsMouseButtonPressed(Settings.HoldKey) then
        CurrentTarget = nil
        LastLockedName = ""
        return
    end

    local targetData = GetClosestTarget()

    if targetData then
        local currentName = GetBossDisplayName(targetData.Model)
        local isNewBoss = (CurrentBossModel ~= targetData.Model)
        
        if isNewBoss then
            CurrentBossModel = targetData.Model
            NotificationCount = 0
        end

        if CurrentTarget ~= targetData.Part or LastLockedName ~= currentName then
            CurrentTarget = targetData.Part
            LastLockedName = currentName
            
            if NotificationCount < 2 then
                NotificationCount = NotificationCount + 1
                ShowToast("Locked on: " .. currentName)
            end
        end

        if math.random(100) <= Settings.HitChance then
            local targetPos = PredictPosition(targetData.Part)
            local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, targetPos)
            Camera.CFrame = targetCFrame
        end
    else
        if CurrentTarget then
            ShowToast("Target Lost")
        end
        CurrentTarget = nil
        if CurrentBossModel and CurrentBossModel:FindFirstChild("Humanoid") and CurrentBossModel.Humanoid.Health <= 0 then
            CurrentBossModel = nil
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end  -- ignore if typing in chat

    if input.KeyCode == Enum.KeyCode.Z then
        Settings.TargetMode = Settings.TargetMode == "Boss" and "Player" or "Boss"
        ShowToast("Mode: " .. Settings.TargetMode .. " Aimbot")
    elseif input.KeyCode == Enum.KeyCode.X then
        Settings.TargetPart = Settings.TargetPart == "Torso" and "Head" or "Torso"
        ShowToast("Target Part: " .. Settings.TargetPart)
    elseif input.KeyCode == Enum.KeyCode.B then
        if Settings.Prediction == 0.12 then
            Settings.Prediction = 0.18
            Settings.PlayerPrediction = 0.12
            ShowToast("Prediction: High")
        else
            Settings.Prediction = 0.12
            Settings.PlayerPrediction = 0.08
            ShowToast("Prediction: Normal")
        end
    end
end)

print("Loaded - Z = Mode | X = Torso/Head | B = Prediction")
