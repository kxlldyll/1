local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local StarterGui = game:GetService("StarterGui")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera

local Settings = {
    Enabled = true,
    HoldKey = Enum.UserInputType.MouseButton2,
    FOV = 140,
    TargetPart = "Torso",
    Smoothing = 0.00,
    HitChance = 100,
    Prediction = 0.1,
    DrawFOV = true,
    FOVColor = Color3.fromRGB(255, 255, 255),
    FOVThickness = 2
}

local HeartKeywords = {"FL", "BL", "Heart", "heart"}

local CurrentTarget = nil
local LastLockedName = ""
local FOVCircle = Drawing.new("Circle")

FOVCircle.Thickness = Settings.FOVThickness
FOVCircle.Color = Settings.FOVColor
FOVCircle.Transparency = 0.75
FOVCircle.Filled = false
FOVCircle.NumSides = 64

local function ShowToast(message)
    StarterGui:SetCore("SendNotification", {Title = "Ro Ghoul", Text = message, Duration = 2})
end

ShowToast("Heart Aimbot loaded.")

local function IsHeart(model)
    if not model or not model:FindFirstChild("Humanoid") then return false end
    local name = model.Name:lower()
    for _, kw in ipairs(HeartKeywords) do
        if name:find(kw:lower()) then return true end
    end
    return false
end

local function GetClosestHeart()
    local closest = nil
    local bestDist = Settings.FOV
    local mousePos = Camera.ViewportSize / 2

    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and IsHeart(obj) then
            local part = obj:FindFirstChild(Settings.TargetPart) or obj:FindFirstChild("HumanoidRootPart")
            if part then
                local screen, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(screen.X, screen.Y) - mousePos).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        closest = {Part = part, Model = obj}
                    end
                end
            end
        end
    end
    return closest
end

local function PredictPosition(part)
    return part.Position + (part.Velocity * Settings.Prediction)
end

RunService.RenderStepped:Connect(function()
    if Settings.DrawFOV then
        FOVCircle.Position = Camera.ViewportSize / 2
        FOVCircle.Radius = Settings.FOV
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end

    if not UserInputService:IsMouseButtonPressed(Settings.HoldKey) then
        CurrentTarget = nil
        return
    end

    local targetData = GetClosestHeart()

    if targetData then
        local name = targetData.Model.Name
        if CurrentTarget ~= targetData.Part or LastLockedName ~= name then
            CurrentTarget = targetData.Part
            LastLockedName = name
            ShowToast("Locked on: " .. name)
        end

        if math.random(100) <= Settings.HitChance then
            local targetPos = PredictPosition(targetData.Part)
            local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, targetPos)
            Camera.CFrame = targetCFrame
        end
    else
        CurrentTarget = nil
    end
end)
